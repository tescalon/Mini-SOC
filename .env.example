# =============================================================================
# Fichier .env - Secrets du Mini-SOC
# CE FICHIER NE DOIT JAMAIS ÊTRE COMMITÉ (voir .gitignore)
# Copier en .env et remplir les valeurs réelles
# =============================================================================

# Mot de passe Elasticsearch (utilisateur elastic)
ELASTIC_PASSWORD=changeme

# Mot de passe Kibana system (utilisateur kibana_system)
# À configurer après le premier démarrage :
# curl -u elastic:$ELASTIC_PASSWORD -X POST http://localhost:9200/_security/user/kibana_system/_password -H "Content-Type: application/json" -d '{"password":"KIBANA_PASSWORD_ICI"}'
KIBANA_PASSWORD=changeme

# Clé de chiffrement Kibana (minimum 32 caractères, aléatoire)
# Générer : openssl rand -hex 32
KIBANA_ENCRYPTION_KEY=changeme_minimum_32_characters_required
