# ------------------ ELK (PC1) ------------------------------------------------

# Mot de passe de l'utilisateur elastic (superadmin Elasticsearch)
ELASTIC_PASSWORD=changeme

# Mot de passe de l'utilisateur systÃ¨me kibana_system
# CrÃ©er aprÃ¨s le premier boot :
#   curl -u elastic:$ELASTIC_PASSWORD -X POST \
#     http://localhost:9200/_security/user/kibana_system/_password \
#     -H "Content-Type: application/json" \
#     -d '{"password":"KIBANA_PASSWORD_ICI"}'
KIBANA_PASSWORD=changeme

# ClÃ© de chiffrement Kibana (minimum 32 caractÃ¨res alÃ©atoires)
# GÃ©nÃ©rer : openssl rand -hex 32
KIBANA_ENCRYPTION_KEY=changeme_minimum_32_characters_required

# ------------------ TheHive / Cortex (PC2) ------------------------------------

# Mot de passe admin TheHive
